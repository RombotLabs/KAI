# MySQL Configuration
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=kaiuser
MYSQL_PASSWORD=kaipassword

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=1

# LMS Configuration (external Mac instance)
# Use host.docker.internal to access Mac host from Docker container
LMS_HOST=host.docker.internal
LMS_PORT=8000
LMS_API_URL=http://host.docker.internal:8000/api
LMS_API_KEY=your_lms_api_key_here
